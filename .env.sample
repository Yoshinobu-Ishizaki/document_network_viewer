# Copy this file to .env and fill in your API keys.
# Only the keys for the selected LLM_PROVIDER are required.

LLM_PROVIDER=anthropic    # anthropic | openai | gemini | gemini-login | claude-code

# Anthropic API key (default)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Claude Code login (no API key needed — uses `claude` CLI OAuth login)
# Run `claude login` once, then set LLM_PROVIDER=claude-code
CLAUDE_CODE_MODEL=claude-haiku-4-5-20251001

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORG_ID=org-...       # optional: for paid org accounts
OPENAI_PROJECT_ID=proj-...  # optional: for paid project accounts

# Google Gemini (API key)
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-flash

# Google Gemini via gcloud ADC (no API key needed — run `gcloud auth application-default login`)
# LLM_PROVIDER=gemini-login
GEMINI_LOGIN_MODEL=gemini-1.5-flash
GEMINI_PROJECT=my-gcp-project   # optional: GCP project ID
GEMINI_LOCATION=us-central1     # optional: defaults to us-central1
